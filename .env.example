# ===========================================================================
# GenBI - Ejemplo de Configuración Global (.env.example)
# ===========================================================================

# --- Credenciales de Base de Datos ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- URLs de Conexión ---
# API App DB
APP_DB_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/genbi_db
# Vanna/Agents Source DB (Chinook)
SOURCE_DB_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/chinook

# --- IA Configuration ---
# Clave de Gemini (obtener en aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
# Modelo a usar
GEMINI_MODEL=gemini-2.5-flash

# --- Settings ---
CORS_ORIGINS=["http://localhost:3000"]
CONTEXT_WINDOW_SIZE=5
VIZ_LOG_DIR=logs
MAX_CORRECT_ATTEMPTS=5
