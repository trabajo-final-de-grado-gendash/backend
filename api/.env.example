# api — Variables de entorno
# Copiar este archivo a .env y completar los valores reales

# Connection string de PostgreSQL para persistencia (sessions, messages, results)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/genbi_db

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Tamaño de la ventana de contexto conversacional (opcional, default=5)
CONTEXT_WINDOW_SIZE=5
