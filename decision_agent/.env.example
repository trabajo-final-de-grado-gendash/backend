# decision_agent — Variables de entorno
# Copiar este archivo a .env y completar los valores reales

# API key de Google Gemini (obligatorio)
GEMINI_API_KEY=your-gemini-api-key-here

# Connection string de PostgreSQL para Chinook (usada por Vanna al ejecutar SQL)
CHINOOK_DB_URL=postgresql+asyncpg://user:password@localhost:5432/chinook

# Tamaño de la ventana de contexto conversacional (opcional, default=5)
CONTEXT_WINDOW_SIZE=5
