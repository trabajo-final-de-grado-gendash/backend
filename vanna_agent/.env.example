# vanna_agent — Variables de entorno
# Copiar este archivo a .env y completar los valores reales

# API key de Google Gemini (obligatorio)
GEMINI_API_KEY=your-gemini-api-key-here

# Modelo de Gemini a usar para text2sql (opcional, default=gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# Connection string de PostgreSQL de Chinook (obligatorio)
# Vanna AI ejecuta los SELECT directamente sobre esta base de datos
CHINOOK_DB_URL=postgresql://user:password@localhost:5432/chinook
